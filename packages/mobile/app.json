{
  "expo": {
    "name": "OpenChamber",
    "slug": "openchamber-mobile",
    "scheme": "openchamber",
    "version": "1.10.2",
    "orientation": "default",
    "icon": "./icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "ai.openchamber.mobile",
      "supportsTablet": true,
      "icon": "./icon.png",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "ai.openchamber.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#111111"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow OpenChamber to scan pairing QR codes."
        }
      ],
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "15d58729-e6c0-40f2-9fd3-0e60a66c5383"
      }
    },
    "owner": "youzini"
  }
}
