{
  "expo": {
    "name": "OpenChamber",
    "slug": "openchamber-mobile",
    "scheme": "openchamber",
    "version": "1.10.2",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "ai.openchamber.mobile",
      "supportsTablet": true,
      "icon": "./icon.png",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "ai.openchamber.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#111111"
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow OpenChamber to scan pairing QR codes."
        }
      ],
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}
